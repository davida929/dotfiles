    layout {
        gaps 4 // Gap between windows
        center-focused-column "never" // Don’t auto-center focused column

        background-color "transparent" 

        preset-column-widths {
            proportion 0.33333
            proportion 0.5
            proportion 0.66667
        }

        struts {}
	focus-ring {
	    width 1
	    active-color "#fabd2f"
	}
    }
